# ─── had.ai Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in your real values
# NEVER commit .env to GitHub

# ── Frontend (React) ──────────────────────────────────────────────────────────
# Your Claude API key from https://console.anthropic.com
REACT_APP_CLAUDE_KEY=your_claude_api_key_here

# Your backend URL (change after deploying to Render)
REACT_APP_BACKEND_URL=http://localhost:5000

# ── Backend (Node.js) ─────────────────────────────────────────────────────────
# Your Claude API key (same key, used by server)
CLAUDE_KEY=your_claude_api_key_here

# Your frontend URL (change after deploying to Vercel)
FRONTEND_URL=http://localhost:3000

# Server port
PORT=5000
